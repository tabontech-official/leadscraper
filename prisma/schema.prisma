generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  AGENCY
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id               String   @id @default(cuid())
  clerkId          String?  @unique
  email            String   @unique
  plan             Plan     @default(FREE)
  uploadsThisMonth Int      @default(0)
  uploadsMonthKey  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  jobs SearchJob[]
  leads Lead[]
  hireShopifyExpertLeads HireShopifyExpertLead[]
}

model SearchJob {
  id              String    @id @default(cuid())
  userId          String
  name            String?
  originalFile    String?
  csvData         Json?
  status          JobStatus @default(PENDING)
  totalRows       Int       @default(0)
  processedRows   Int       @default(0)
  totalLeadsFound Int       @default(0)
  resultsPerRow   Int       @default(10)
  searchProvider  String    @default("serpapi")
  runTechImmediately Boolean @default(true)
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@index([userId])
  @@index([status])
}

model Lead {
  id               String   @id @default(cuid())
  userId           String
  jobId            String?

  businessName     String?
  website          String?
  domain           String?
  phone            String?
  email            String?

  address          String?
  city             String?
  state            String?
  zipCode          String?
  category         String?

  googleListingUrl String?
  source           String?

  facebook         String?
  instagram        String?
  linkedin         String?
  twitter          String?
  tiktok           String?
  youtube          String?

  contactPage      String?
  aboutPage        String?

  primaryTech      String?
  allTech          Json?
  techConfidence   Int?
  techSignals      Json?

  rawData          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  SearchJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([userId, domain])
  @@index([userId])
  @@index([jobId])
  @@index([primaryTech])
  @@index([state])
  @@index([category])
  @@index([zipCode])
}

model HireShopifyExpertLead {
  id              String    @id @default(cuid())
  userId          String
  name            String?
  website         String?
  profileUrl      String?
  email           String?
  phone           String?
  country         String?
  city            String?
  services        String?
  specialization  String?
  rating          Float?
  reviewsCount    Int?
  socialLinks     Json?
  sourceUrl       String?
  description     String?
  category        String?
  status          String?   @default("active")
  dateScraped     DateTime? @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([country])
  @@index([category])
  @@index([rating])
}
